# Granite endpoint used by ai/granite_orchestrator_loader.py
GRANITE_ENDPOINT=

# Granite API credential used as a Bearer token by default
GRANITE_API_KEY=

# Optional model identifier if your Granite endpoint requires it
GRANITE_MODEL=

# Enable structured Granite request/response logging (true/false)
RACESIGHT_GRANITE_DEBUG_LOG=false

# Optional log directory for Granite debug logs
RACESIGHT_LOG_DIR=logs

# Telemetry source (set URL or file; URL takes precedence)
RACESIGHT_SENSOR_FEED_URL=
RACESIGHT_SENSOR_FEED_FILE=data/live_sensor_feed.json

